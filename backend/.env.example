# ── MediScan AI – Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Database
DATABASE_URL=postgresql://postgres:mediscan2024@localhost:5432/medical

# Security – generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
APP_NAME=MediScan AI
APP_VERSION=2.0.0
DEBUG=false

# URLs (used for share link generation)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760          # 10 MB in bytes
DELETE_FILES_AFTER_PROCESSING=true
DEFAULT_SAVE_REPORT=false

# OCR
OCR_ENGINE=easyocr
OCR_LANGUAGE=en
MIN_OCR_CONFIDENCE=0.5

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ── AI / Gemini ──────────────────────────────────────────────────────────────
# Set ENABLE_AI_EXPLANATIONS=true and provide your Gemini API key for AI-powered
# explanations. Without this, the system uses rule-based explanations.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
ENABLE_AI_EXPLANATIONS=false

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_PDF_EXPORT=true
ENABLE_SHARING=true
